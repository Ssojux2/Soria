{
  "scan": {
    "supported_extensions": ["mp3", "wav", "aiff", "m4a", "flac"],
    "max_parallel_metadata_jobs": 4
  },
  "embedding": {
    "provider": "gemini",
    "model": "text-embedding-004",
    "batch_size": 8,
    "retry_count": 4,
    "timeout_sec": 30
  },
  "analysis": {
    "preview_bins": 256,
    "middle_weighting": "1:3:1",
    "preferred_sample_rate": 22050
  },
  "external_metadata": {
    "rekordbox_import": "xml",
    "serato_import": "csv",
    "direct_serato_write_enabled": false
  },
  "export": {
    "default_format": "rekordboxXML",
    "serato_safe_package": ["m3u", "csv", "txt"]
  },
  "recommendation": {
    "weights": {
      "embed": 0.45,
      "bpm": 0.15,
      "key": 0.15,
      "energy": 0.1,
      "introOutro": 0.1,
      "external": 0.05
    }
  }
}
